    # 1. Берем образ Node.js (как фундамент)
    FROM node:18-alpine

    # 2. Создаем папку внутри контейнера, где будет лежать код
    WORKDIR /app

    # 3. Копируем файлы с зависимостями
    COPY package*.json ./

    # 4. Устанавливаем библиотеки внутри контейнера
    RUN npm install
   
    # 5. Копируем весь остальной код
    COPY . .
   
    # 6. Открываем порт 5000 (на котором будет работать сервер)
    EXPOSE 5000
   
    # 7. Команда для запуска (будем запускать через ts-node)
    CMD ["npm", "run", "dev"]